# Production: set DOMAIN in .env (e.g. trainer.example.com).
# FRONTEND_UPSTREAM: for docker stack deploy use st2_frontend (Swarm DNS); for compose use frontend.
{$DOMAIN} {
  handle /grafana* {
    reverse_proxy st2_grafana:3000 {
      transport http {
        read_timeout 300s
        write_timeout 300s
      }
    }
  }
  handle {
    reverse_proxy {$FRONTEND_UPSTREAM}:80 {
      transport http {
        read_timeout 300s
        write_timeout 300s
      }
    }
  }
}
