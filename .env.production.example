# Production .env for production server — copy to .env and fill values.
# Deploy host config is in deploy.env (see deploy.env.example).
# Required for docker-compose.prod.yml (Caddy)
# DOMAIN: landing page (tsspro.tech)
# APP_DOMAIN: main app (app.tsspro.tech)
DOMAIN=tsspro.tech
APP_DOMAIN=app.tsspro.tech
LANDING_UPSTREAM=st2_landing
FRONTEND_UPSTREAM=st2_frontend

# Landing CTA links point to app. For dev: https://dev.app.tsspro.tech
VITE_APP_URL=https://app.tsspro.tech

# App API URL. Frontend build uses this for API requests.
EXPO_PUBLIC_API_URL=https://app.tsspro.tech

# Backend CORS: allow frontend and landing origins. REQUIRED in production — without explicit list, CORS falls back to * and is rejected when APP_ENV=production.
CORS_ORIGINS=https://tsspro.tech,https://www.tsspro.tech,https://app.tsspro.tech,https://www.app.tsspro.tech

# PostgreSQL
POSTGRES_USER=tssproai
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=tssproai

# Gemini
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Intervals.icu
INTERVALS_ICU_BASE_URL=https://intervals.icu/api/v1
# OAuth (register app at david@intervals.icu)
# INTERVALS_CLIENT_ID=
# INTERVALS_CLIENT_SECRET=
# INTERVALS_OAUTH_REDIRECT_URI=https://app.tsspro.tech/api/v1/intervals/oauth/callback
# FRONTEND_BASE_URL=https://app.tsspro.tech

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# App — use strong random values in production. REQUIRED: APP_ENV=production enables ENCRYPTION_KEY check and CORS allowlist (rejects wildcard *).
APP_ENV=production
SECRET_KEY=change_me_in_production
DEBUG=false

# Security: enable HSTS (Strict-Transport-Security) when serving over HTTPS. Set to true in production.
ENABLE_HSTS=true

# JWT RS256 (recommended for production / multi-instance). If both set, access tokens use RS256.
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste PEM contents; in .env use \n for newlines inside the value.
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Sentry (error tracking). Backend and frontend can use the same DSN or separate project DSNs.
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN)
SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/1234567
SENTRY_ENVIRONMENT=production
# Frontend (optional; if unset, backend SENTRY_DSN is used for frontend build)
# EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@o123456.ingest.sentry.io/1234567

# Umami (self-hosted analytics). Add DNS A-record for analytics.tsspro.tech.
# After first deploy: open https://analytics.tsspro.tech, login admin/umami, create website, copy Website ID.
ANALYTICS_DOMAIN=analytics.tsspro.tech
UMAMI_UPSTREAM=st2_umami
UMAMI_DB_PASSWORD=change_me_umami_db
# Generate: openssl rand -hex 16
UMAMI_APP_SECRET=replace_with_random_32_char_string
# UMAMI_HOST_URL=https://analytics.tsspro.tech
# UMAMI_DB_HOST=st2_umami_db  # for Swarm; use umami_db for docker compose
VITE_UMAMI_URL=https://analytics.tsspro.tech
VITE_UMAMI_WEBSITE_ID=

# Optional: orchestrator cron hours (0-23, comma-separated)
# ORCHESTRATOR_CRON_HOURS=7,16

# S3/MinIO (photo storage). In production NEVER use default minioadmin — set strong credentials.
# If unset with docker-compose.prod.yml, compose will fail (required for MinIO security).
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=your_minio_username
S3_SECRET_KEY=your_minio_password
S3_BUCKET=tssproai

# PostgreSQL backup to S3 (required for prod backup container; Selectel or AWS)
S3_BACKUP_BUCKET=your-backup-bucket
S3_BACKUP_ACCESS_KEY=
S3_BACKUP_SECRET_KEY=
# S3_BACKUP_ENDPOINT=   # e.g. https://s3.selcdn.ru for Selectel; leave empty for AWS
# S3_BACKUP_PREFIX=backups/postgres/
# BACKUP_CRON_SCHEDULE=0 3 * * *
# BACKUP_RETENTION_DAYS=30

# Stripe (billing). Get keys from https://dashboard.stripe.com
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_MONTHLY=
# STRIPE_PRICE_ANNUAL=

# Resend (email: password reset, service notifications). Get API key at https://resend.com
RESEND_API_KEY=
MAIL_FROM=noreply@yourdomain.com
