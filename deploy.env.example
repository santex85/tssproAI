# Deploy config: copy to deploy.env and set your hosts.
# deploy.env is gitignored; do not commit real IPs/hostnames.
# Used by Makefile for deploy targets (make deploy, make deploy-dev).

DEPLOY_TARGET=prod
DEPLOY_HOST=your-prod-host-or-ip
DEPLOY_USER=root
DEPLOY_PATH=/root/smart_trainer

# For make deploy-dev
DEV_DEPLOY_HOST=your-dev-host-or-ip
DEV_DEPLOY_USER=root
DEV_DEPLOY_PATH=/root/smart_trainer
