# PostgreSQL (used by docker-compose for postgres and backend DATABASE_URL)
POSTGRES_USER=smart_trainer
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=smart_trainer

# Gemini (backend)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Intervals.icu (backend)
INTERVALS_ICU_BASE_URL=https://intervals.icu/api/v1

# S3/MinIO (photo storage)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=smart-trainer

# S3 for PostgreSQL backups (production; used by backup container and restore-from-s3.sh)
# Can be same bucket as above with S3_BACKUP_PREFIX, or separate bucket (e.g. Selectel, AWS).
# S3_BACKUP_BUCKET=your-backup-bucket
# S3_BACKUP_ACCESS_KEY=
# S3_BACKUP_SECRET_KEY=
# S3_BACKUP_ENDPOINT=   # e.g. https://s3.selcdn.ru for Selectel; leave empty for AWS
# S3_BACKUP_PREFIX=backups/postgres/
# BACKUP_CRON_SCHEDULE=0 3 * * *   # 03:00 UTC daily
# BACKUP_RETENTION_DAYS=30         # 0 = keep all

# Encryption for stored tokens (backend). Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Production (Caddy). Required when using docker-compose.prod.yml. Example: your-domain.com
DOMAIN=example.com

# App (backend). Set APP_ENV=production on production to enable ENCRYPTION_KEY check
APP_ENV=development
SECRET_KEY=change_me_in_production
DEBUG=false

# JWT: optional RS256 (for multi-instance). If both set, access tokens use RS256; else HS256 with SECRET_KEY.
# Generate RSA key pair: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# In .env use single line with \n for newlines, or pass PEM content.
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# Orchestrator: run daily decision at these hours (0-23), comma-separated. Default: 7,16 (07:00 and 16:00)
# ORCHESTRATOR_CRON_HOURS=7,16

# Stripe (backend billing)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Frontend Docker build: limit Node heap (MB) to avoid OOM on low-RAM dev server. Default 2048; use 1536 or 1024 if build still OOMs.
# NODE_MEMORY_MB=2048

# Sentry (backend). Optional; leave empty to disable.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
